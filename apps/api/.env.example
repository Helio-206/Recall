APP_NAME=Recall API
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://recall:recall@localhost:5433/recall
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-before-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOCAL_STORAGE_PATH=./storage

INGESTION_QUEUE_NAME=recall-ingestion
INGESTION_JOB_TIMEOUT_SECONDS=900
INGESTION_RETRY_ATTEMPTS=2
INGESTION_MAX_PLAYLIST_ITEMS=100
YT_DLP_SOCKET_TIMEOUT_SECONDS=20
TRANSCRIPT_QUEUE_NAME=recall-transcripts
TRANSCRIPT_JOB_TIMEOUT_SECONDS=7200
TRANSCRIPT_RETRY_ATTEMPTS=1
TRANSCRIPT_TMP_PATH=/tmp/recall-transcripts
TRANSCRIPT_PREFER_YOUTUBE_CAPTIONS=true
WHISPER_MODEL_NAME=tiny
WHISPER_LANGUAGE=
WHISPER_FP16=false
AI_PROVIDER=heuristic
AI_PROMPT_VERSION=phase4-v1
AI_QUEUE_NAME=ai-summary
AI_RETRY_ATTEMPTS=2
AI_JOB_TIMEOUT_SECONDS=480
AI_CHUNK_TARGET_CHARS=1800
AI_CHUNK_OVERLAP_SEGMENTS=1
AI_REQUEST_TIMEOUT_SECONDS=45
AI_REQUEST_RETRIES=2
AI_RATE_LIMIT_PER_MINUTE=20
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_APP_NAME=Recall
OPENROUTER_SITE_URL=http://localhost:3000
CURRICULUM_PROVIDER=heuristic
SEARCH_ENABLED=true
SEARCH_BACKEND=meilisearch
SEARCH_URL=http://localhost:7700
SEARCH_API_KEY=
SEARCH_INDEX_UID=learning-content
